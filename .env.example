EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google sign-in (real builds only, not Expo Go). From Firebase console →
# Authentication → Sign-in method → Google → Web SDK configuration:
#   WEB_CLIENT_ID = the "Web client ID" shown there (gets the Firebase idToken)
# From Google Cloud console → APIs & Services → Credentials, the OAuth 2.0
# client ID of type "iOS" (create one for bundle com.plato.workouts if missing):
#   IOS_CLIENT_ID = "<id>.apps.googleusercontent.com"
#   and put its REVERSED form ("com.googleusercontent.apps.<id>") in
#   app.json → plugins → @react-native-google-signin/google-signin → iosUrlScheme
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
